user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /run/nginx/nginx.pid;

events {
    worker_connections 1024;
}

http {
    include      /etc/nginx/mime.types;
    default_type application/octet-stream;
    sendfile     on;
    keepalive_timeout 65;

    # Preserve pcd-next once set — don't let favicon/asset requests overwrite
    # the original console URL captured by the first unauthenticated request.
    map $cookie_pcd_next $pcd_next_cookie {
        ""      $request_uri;
        default $cookie_pcd_next;
    }

    upstream novnc_backend {
        ip_hash;
@@UPSTREAM_SERVERS@@
    }

    # HTTP: ACME challenge + redirect to HTTPS
    server {
        listen 80;
        server_name ${DOMAIN};

        location /.well-known/acme-challenge/ {
            root /var/www/acme;
        }

        location / {
            return 301 https://$host:6080$request_uri;
        }
    }

    # HTTPS on 6080: Keystone auth gate + WebSocket proxy to noVNC backend
    server {
        listen 6080 ssl;
        server_name ${DOMAIN};

        ssl_certificate     /etc/pcd-proxy/certs/fullchain.pem;
        ssl_certificate_key /etc/pcd-proxy/certs/key.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;
        ssl_session_cache   shared:SSL:10m;

        # Auth subrequest endpoint — internal only, never reachable directly
        location = /auth_verify {
            internal;
            proxy_pass              http://127.0.0.1:9000/auth_verify;
            proxy_pass_request_body off;
            proxy_set_header        Content-Length "";
            proxy_set_header        X-Original-URI $request_uri;
        }

        # Login UI — no auth_request guard (would cause infinite redirect)
        location /login {
            proxy_pass http://127.0.0.1:9000/login;
        }

        # noVNC/websockify proxy — every request checked via auth_request
        location / {
            auth_request /auth_verify;
            error_page 401 = @require_login;

            proxy_pass            https://novnc_backend;
            proxy_ssl_verify      off;
            proxy_http_version    1.1;
            proxy_set_header      Upgrade $http_upgrade;
            proxy_set_header      Connection "upgrade";
            proxy_set_header      Host $host;
            proxy_set_header      X-Forwarded-Proto https;
            proxy_set_header      X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_read_timeout    3600s;
            proxy_send_timeout    3600s;
        }

        location = /favicon.ico { return 204; }

        location @require_login {
            add_header Set-Cookie "pcd-next=$pcd_next_cookie; Path=/; Secure; HttpOnly; SameSite=Strict" always;
            return 302 /login;
        }
    }
}
